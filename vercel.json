{
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/cron-reminders.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!_expo|assets|favicon.ico).*)", "destination": "/index.html" }
  ],
  "crons": []
}
