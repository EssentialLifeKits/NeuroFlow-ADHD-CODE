{
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!_expo|assets|favicon.ico).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron-reminders", "schedule": "0 0 * * *" }
  ]
}
